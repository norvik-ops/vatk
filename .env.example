# Database
VAKT_DB_URL=postgres://vakt:ERSETZEN_SIE_DIESEN_WERT@localhost:5432/vakt?sslmode=disable
# Production alternative: read URL from a file to keep credentials out of `docker inspect`.
# VAKT_DB_URL_FILE=/run/secrets/vakt_db_url
# Optional: DB connection pool size. Default 25. Increase for high-traffic or pgBouncer setups.
# VAKT_DB_MAX_CONNS=25

# Redis — Passwort schützt Rate-Limit-Counter, Session-Deny-List und Job-Queue
# vor unauthentifiziertem Zugriff aus dem Docker-Netzwerk.
# Generierung: openssl rand -hex 32
REDIS_PASSWORD=ERSETZEN_SIE_DIESEN_WERT
VAKT_REDIS_URL=redis://:ERSETZEN_SIE_DIESEN_WERT@redis:6379

# Security — MUSS ein kryptografisch zufälliger 32-Byte-Hex-String sein.
# Niemals Nullen oder andere wiederholte Zeichen verwenden.
# Generierung: openssl rand -hex 32
# WARNUNG: Gleiche Bytes (z.B. 000...0 oder aaa...a) werden beim Start abgelehnt.
VAKT_SECRET_KEY=ERSETZEN_SIE_DIESEN_WERT
# Production alternative: read from a file to keep master key out of `docker inspect`.
# VAKT_SECRET_KEY_FILE=/run/secrets/vakt_secret_key

# Pro-Lizenzkey (optional — wird per E-Mail nach dem Kauf zugeschickt)
# VAKT_LICENSE_KEY=

# Modules (all enabled by default)
VAKT_MODULES_ENABLED=vaktscan,vaktcomply,vaktvault,vaktaware,vaktprivacy

# App
APP_VERSION=0.1.0
VAKT_API_PORT=8080
AUTO_MIGRATE=false
# Update-Benachrichtigung (opt-in) — einmal täglich prüft die App ob eine neue Version verfügbar ist.
# Dabei werden keinerlei Daten gesendet — nur ein GET-Request an die öffentliche GitHub-API.
# VAKT_UPDATE_CHECK=false
# Demo-Modus: Füllt die DB mit Beispieldaten und aktiviert den Demo-Login (admin@vakt.local / admin1234)
# SMTP (dev — mailpit; use port 587/465 + credentials for production)
VAKT_SMTP_HOST=localhost
VAKT_SMTP_PORT=1025
VAKT_SMTP_USER=                    # required for port 587/465 (production)
VAKT_SMTP_PASS=                    # required for port 587/465 (production)
VAKT_SMTP_FROM=noreply@example.com  # From address for Vakt Aware campaign emails

# Frontend public URL (used by SecReflex for tracking pixel / click links in emails)
VAKT_FRONTEND_URL=http://localhost:5173

# Vakt Scan — OpenVAS (optional, extern — Trivy und Nuclei sind im Docker-Image gebündelt)
# VAKT_OPENVAS_URL=http://openvas:9392
# VAKT_OPENVAS_USER=admin
# VAKT_OPENVAS_PASS=

# KI-Compliance-Berater — Community-Feature, default-on seit v0.6.x.
# Ollama startet automatisch mit `docker compose up`; ollama-init zieht
# beim ersten Start einmalig das Modell qwen2.5:3b (~1.9 GB, Apache 2.0,
# CPU-tauglich, ~2 GB RAM Live-Footprint).
# Zum Deaktivieren auf kleinen VMs (< 8 GB RAM): VAKT_AI_PROVIDER=disabled
# UND ollama+ollama-init aus docker-compose.yml entfernen oder per
# compose-override deaktivieren.
VAKT_AI_PROVIDER=ollama
VAKT_AI_BASE_URL=http://ollama:11434/v1
VAKT_AI_API_KEY=
VAKT_AI_MODEL=qwen2.5:3b
#
# Modell-Alternativen (alle CPU-fähig):
#   qwen2.5:3b          ~1.9 GB RAM, Apache 2.0   — Default, schnell + gute DE-Qualität
#   llama3.2:3b         ~2.0 GB RAM, Llama Lic.   — Meta, gut balanciert
#   llama3.2:1b         ~1.3 GB RAM, Llama Lic.   — sehr schonend, geringere Qualität
#   phi3.5:mini         ~2.3 GB RAM, MIT          — Microsoft, sehr gut bei strukturierten Outputs
#   gemma2:2b           ~1.6 GB RAM, Gemma Terms  — Google, restriktivere Lizenz
#
# Cloud-Alternative (EU, DSGVO-konform via AVV mit Mistral):
#   VAKT_AI_BASE_URL=https://api.mistral.ai/v1
#   VAKT_AI_API_KEY=sk-...
#   VAKT_AI_MODEL=mistral-small-latest
#   → schneller (50-100 tok/s), aber Daten verlassen die Instanz

# Postgres (used by docker-compose.yml prod) — auto-generated by install.sh
POSTGRES_PASSWORD=ERSETZEN_SIE_DIESEN_WERT

# Polar.sh — License issuance (operator-side, Norvik use only)
# Required to receive purchase webhooks from Polar.sh and issue license keys.
# VAKT_POLAR_WEBHOOK_SECRET=your-polar-webhook-signing-secret
# VAKT_LICENSE_PRIVATE_KEY=base64url-encoded-ecdsa-p256-private-key-pem

# LemonSqueezy — kept for backward compat (superseded by Polar.sh)
# VAKT_LS_WEBHOOK_SECRET=your-lemonsqueezy-webhook-signing-secret

# Staging mode (only used on the Vakt demo server)
