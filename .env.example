# Database
VAKT_DB_URL=postgres://vakt:ERSETZEN_SIE_DIESEN_WERT@localhost:5432/vakt?sslmode=disable

# Redis
VAKT_REDIS_URL=redis://localhost:6379

# Security — generate with: openssl rand -hex 32
VAKT_SECRET_KEY=ERSETZEN_SIE_DIESEN_WERT  # generate with: openssl rand -hex 32

# Pro-Lizenzkey (optional — wird per E-Mail nach dem Kauf zugeschickt)
# VAKT_LICENSE_KEY=

# Modules (all enabled by default)
VAKT_MODULES_ENABLED=secpulse,secvitals,secvault,secreflex,secprivacy

# App
APP_VERSION=0.1.0
VAKT_API_PORT=8080
AUTO_MIGRATE=false
# Update-Benachrichtigung (opt-in) — einmal täglich prüft die App ob eine neue Version verfügbar ist.
# Dabei werden keinerlei Daten gesendet — nur ein GET-Request an die öffentliche GitHub-API.
# VAKT_UPDATE_CHECK=false
# Demo-Modus: Füllt die DB mit Beispieldaten und aktiviert den Demo-Login (admin@vakt.local / admin1234)
# SMTP (dev — mailpit; use port 587/465 + credentials for production)
VAKT_SMTP_HOST=localhost
VAKT_SMTP_PORT=1025
VAKT_SMTP_USER=                    # required for port 587/465 (production)
VAKT_SMTP_PASS=                    # required for port 587/465 (production)
VAKT_SMTP_FROM=noreply@example.com  # From address for Vakt Aware campaign emails

# Frontend public URL (used by SecReflex for tracking pixel / click links in emails)
VAKT_FRONTEND_URL=http://localhost:5173

# KI-Compliance-Berater — standardmäßig aktiviert via lokalem Ollama (kein GPU nötig)
# Modell einmalig laden: docker compose exec ollama ollama pull llama3.2:3b
# Zum Deaktivieren: VAKT_AI_PROVIDER=disabled
# AI provider: ollama (local, default) or openai (requires VAKT_OPENAI_API_KEY)
# Set to 'ollama' to enable AI features. Requires: docker compose --profile ai up
VAKT_AI_PROVIDER=ollama
VAKT_AI_BASE_URL=http://ollama:11434/v1
VAKT_AI_API_KEY=
VAKT_AI_MODEL=llama3.2:3b
#
# Alternativen:
#   CPU-freundlich (2 GB RAM):  llama3.2:3b | phi3.5:mini | qwen2.5:3b
#   Cloud (EU, DSGVO):          VAKT_AI_BASE_URL=https://api.mistral.ai/v1
#                               VAKT_AI_API_KEY=sk-...
#                               VAKT_AI_MODEL=mistral-small-latest

# Postgres (used by docker-compose.yml prod) — auto-generated by install.sh
POSTGRES_PASSWORD=ERSETZEN_SIE_DIESEN_WERT

# LemonSqueezy — License issuance (operator-side)
# Required if you operate your own license issuance server
# VAKT_LS_WEBHOOK_SECRET=your-lemonsqueezy-webhook-signing-secret
# VAKT_LICENSE_PRIVATE_KEY=base64url-encoded-ecdsa-p256-private-key-pem

# Staging mode (only used on the Vakt demo server)
